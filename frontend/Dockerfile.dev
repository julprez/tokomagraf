# ============================================================
# Dockerfile.dev — Frontend development con Vite HMR
# ============================================================

FROM node:20-alpine

WORKDIR /app

# Instalar dependencias (cacheable)
COPY package.json ./
RUN npm install

# Copiar archivos de configuración (necesarios para Vite)
COPY tsconfig.json tsconfig.node.json tailwind.config.js postcss.config.js ./

# Exponer puerto de Vite
EXPOSE 5173

# Iniciar Vite en modo desarrollo con HMR
CMD ["npx", "vite", "--host", "0.0.0.0", "--port", "5173"]
