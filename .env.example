# ============================================================
# tokomagraf — Variables de Entorno
# Copiá este archivo a .env y editá los valores
#   cp .env.example .env
# ============================================================

# ── Base de Datos ──
DB_PASSWORD=cambiame-por-una-contrasena-segura

# ── Seguridad ──
# Generá un secreto fuerte: openssl rand -hex 32
JWT_SECRET=cambiame-por-un-secreto-largo-y-aleatorio

# ── Dominio (opcional) ──
# Si tenés dominio, Caddy obtiene SSL/HTTPS automático con Let's Encrypt.
# Ejemplo: miscriptos.com
# Dejalo vacío para usar solo HTTP con la IP del servidor.
DOMAIN=
