# ============================================================
# Caddyfile — Auto-SSL reverse proxy para tokomagraf
#
# - Si DOMAIN está configurado → HTTPS automático con Let's Encrypt
# - Si DOMAIN está vacío → HTTP simple en puerto 80
# ============================================================

{$DOMAIN:localhost} {
    # Headers de seguridad
    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "0"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' http://localhost:* https://*;"
    }

    # Comprimir respuestas
    encode gzip zstd

    # Reverse proxy a la app
    reverse_proxy frontend:80 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Logs
    log {
        output stdout
        format console
    }
}
